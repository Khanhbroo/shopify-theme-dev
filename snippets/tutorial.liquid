{% comment %}
  {%- assign myVariable = "Hello World" -%}
  {{- myVariable -}}
{% endcomment %}

{%- comment -%} This is a comment and this should not be rerendered {%- endcomment -%}

<!-- html comment -->

{% comment %} String {% endcomment %}
{% assign my_string = '1234' %}
{{ my_string }}

<br>

{% comment %} Number {% endcomment %}
{% assign my_number = 123 %}
{% assign my_floating_point = 123.5 %}

{{ my_number }}, {{ my_floating_point }}

<br>

{% comment %} Boolean {% endcomment %}
{% assign my_boolean = true %}
{{ my_boolean }}

<br>

{% comment %} nil or null {% endcomment %}
{% assign my_nil = null %}
{{ my_nil }}

{% if undefined_variable == null %}
  <p>undefined_variable equals to nil</p>
{% endif %}

<br>

{% comment %} Array {% endcomment %}
{{ product.tags.size }}

<br>

{% for tag in product.tags %}
  {{ tag }}
  <br>
{% endfor %}

{% comment %} Object {% endcomment %}
<p>{{ product.images[0].width }}</p>

{% comment %} Capture {% endcomment %}
{% capture html %}
    <div>
        <p>Hello {{ product.title }}</p>
    </div>
{% endcapture %}

<div>{{ html }}</div>

{% comment %} Condition {% endcomment %}
{% assign my_variable = 11 %}
{% if my_variable > 10 %}
  <p>Variable greater than 10</p>
{% elsif my_variable > 5 %}
  <p>Variable greater than 3</p>
{% else %}
  <p>Variable not greater than 3</p>
{% endif %}

{% if product.title contains 'Snowboard' %}
  <p>Contained!</p>
{% else %}
  <p>Not contained!</p>
{% endif %}

{% if product.tags contains 'Accessory' %}
  <p>Accessory</p>
{% else %}
  <p>Not accessory</p>
{% endif %}

{{ product.tags | find: 'Acc' | default: 'Can not find' }}

{% comment %} Unless {% endcomment %}
{% unless product.tags contains 'Hohoho' %}
  <p>There's no Hohoho here</p>
{% endunless %}

<br>

{% comment %} Condition separated {% endcomment %}
{% assign is_a_snowboard = false %}
{% if product.title contains 'Snowboard' and product.price > 60000 %}
  {% assign is_a_snowboard = true %}
{% endif %}

{% if is_a_snowboard or product.type == 'snowwhite' %}
  <p>Affordable price</p>
{% else %}
  <p>Not affordable price</p>
{% endif %}

{% comment %} Case {% endcomment %}
{%- if product.type != blank -%}
  {%- case product.type -%}
    {% when 'snowboard' %}
      <p>This is a snowboard</p>
    {% when 'accessories' %}
      <p>This is a ski wax</p>
    {% when 'giftcard' %}
      <p>This is a gift card</p>
    {% else %}
      <p>This is something else</p>
  {%- endcase -%}
{%- endif -%}

{% if product.title %}
  <p>This is the product title: {{ product.title }}</p>
{% endif %}

{% for product in collection.products limit: 5 offset: 5 %}
  <p
    style="
        {% if forloop.first %}
       color: green
      {% elsif forloop.last %}
       color: red
      {% endif %}
    "
  >
    {{ forloop.index }} - {{ product.title }}
  </p>

  {% if product.tags.size > 0 %}
    <h4>Tags</h4>
    <ul>
      {% for tag in product.tags %}
        {% if tag == 'Sport' %}
          {% continue %}
        {% endif %}
        <li>Product Index: {{ forloop.parentloop.index }} | Tags: {{ tag }}</li>
      {% endfor %}
    </ul>
  {% endif %}
{% else %}
  <p>This collection has no products</p>
{% endfor %}

{% for i in (1..5) %}
  {{ i }}
{% endfor %}

{% paginate collection.products by 4 %}
  {% for product in collection.products limit: 4 %}
    <p>{{ product.title }}</p>
  {% endfor %}

  {{ paginate | default_pagination }}
{% endpaginate %}
